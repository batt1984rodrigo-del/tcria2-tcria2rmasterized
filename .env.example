# Copy to .env.local and fill secrets only on your machine or deployment platform.
OPENAI_API_KEY=
TCRIA_ENV=development
TCRIA_OPENAI_MODEL=gpt-5.6-sol
TCRIA_REASONING_EFFORT=medium
TCRIA_PILOT_TOKEN=change-me
TCRIA_JOB_ROOT=./tcria_jobs
